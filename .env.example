# Required: Coda API token (https://coda.io/account#apiSettings)
CODA_API_TOKEN=

# Optional: Disable all write operations
# CODA_READ_ONLY=false

# Optional: Custom API base URL
# CODA_BASE_URL=https://coda.io/apis/v1

# Optional: HTTP timeout in seconds
# CODA_TIMEOUT=30

# Optional: SSL certificate verification
# CODA_SSL_VERIFY=true
